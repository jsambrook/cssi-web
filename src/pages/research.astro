---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/Section.astro';
import { pageTitle, pageDescription, header, papers } from '../data/pages/research';
---

<PageLayout pageTitle={pageTitle} description={pageDescription}>
  <Section background="muted">
    <div class="max-w-3xl mx-auto text-center space-y-4">
      <p class="text-xs uppercase tracking-wider text-accent">{header.label}</p>
      <h1 class="text-4xl sm:text-5xl">{header.heading}</h1>
      <p class="text-muted-foreground">{header.subheading}</p>
    </div>
  </Section>

  <Section>
    <div class="max-w-5xl mx-auto grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        papers.map((paper) => (
          <article class="rounded-[var(--radius)] border border-border bg-background p-6 shadow-sm">
            <div class="flex items-center justify-between gap-3 mb-4">
              <span class="text-xs uppercase tracking-wider text-muted-foreground">
                {paper.domain}
              </span>
              <span
                class:list={[
                  'text-xs font-medium rounded-full px-2.5 py-1',
                  paper.status === 'Published'
                    ? 'bg-feature-green-bg text-feature-green'
                    : 'bg-feature-amber-bg text-feature-amber',
                ]}
              >
                {paper.status}
              </span>
            </div>

            <h2 class="text-xl mb-3 leading-tight">{paper.title}</h2>
            <p class="text-sm text-muted-foreground mb-4">{paper.summary}</p>
            <p class="text-xs text-muted-foreground mb-5">Method: {paper.method}</p>

            {paper.href ? (
              <a href={paper.href} class="text-primary hover:text-primary/80 font-medium text-sm">
                Read paper &rarr;
              </a>
            ) : (
              <span class="text-sm text-muted-foreground">Publication page coming soon.</span>
            )}
          </article>
        ))
      }
    </div>
  </Section>
</PageLayout>
