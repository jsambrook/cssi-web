import { siteConfig } from '../../../data/site';

const title = 'Theory of Constraints: A Practical Guide';
const description =
  'How TOC identifies the one constraint limiting your system and resolves it. The method, the thinking tools, and how we apply them.';

const pageUrl = `${siteConfig.siteUrl}/approach/theory-of-constraints`;

const breadcrumb = buildBreadcrumbSchema([
  { name: 'Home', href: '/' },
