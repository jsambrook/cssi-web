---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/Section.astro';
import CTASection from '../components/CTASection.astro';
import { pageTitle, pageDescription, header, steps, cta } from '../data/pages/approach';
---

<PageLayout pageTitle={pageTitle} description={pageDescription}>
  <Section background="muted">
    <div class="max-w-3xl mx-auto text-center space-y-4">
      <p class="text-xs uppercase tracking-wider text-accent">{header.label}</p>
      <h1 class="text-4xl sm:text-5xl">{header.heading}</h1>
      <p class="text-muted-foreground">{header.subheading}</p>
    </div>
  </Section>

  <Section>
    <div class="max-w-4xl mx-auto grid gap-6 md:grid-cols-2">
      {
        steps.map((step) => (
          <div class="space-y-3">
            <h2 class="text-xl">{step.title}</h2>
            <p class="text-sm text-muted-foreground">{step.description}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <Section>
    <div class="max-w-3xl mx-auto space-y-4">
      <p class="text-muted-foreground">
        Our work is grounded in the Theory of Constraints, a systematic method for identifying and
        resolving the core problems that keep organizations stuck. Developed by physicist Eli
        Goldratt, TOC starts from a simple premise: every system has one constraint that limits its
        performance. Find that constraint, and you know where to focus. Address it directly, and the
        whole system moves.
      </p>
      <a
        href="/approach/theory-of-constraints"
        class="inline-block text-primary hover:text-primary/80 font-medium"
      >
        Learn more about TOC and how we apply it &rarr;
      </a>
    </div>
  </Section>

  <CTASection
    headline={cta.headline}
    description={cta.description}
    primaryCta={cta.primaryCta}
    secondaryCta={cta.secondaryCta}
    footnote={cta.footnote}
  />
</PageLayout>
