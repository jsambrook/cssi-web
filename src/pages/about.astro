---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/Section.astro';
import CTASection from '../components/CTASection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import { pageTitle, pageDescription, header, content, credentials, cta } from '../data/pages/about';
import { buildFounderSchema } from '../data/schema';
---

<PageLayout pageTitle={pageTitle} description={pageDescription} jsonLd={[buildFounderSchema()]}>
  <Section background="muted">
    <div class="max-w-3xl mx-auto text-center space-y-4">
      <p class="text-xs uppercase tracking-wider text-accent">{header.label}</p>
      <h1 class="text-4xl sm:text-5xl">{header.heading}</h1>
      <p class="text-muted-foreground">{header.subheading}</p>
      <div class="pt-4">
        <picture>
          <source srcset="/images/headshots/john-sambrook-headshot-1200.webp" type="image/webp" />
          <img
            src="/images/headshots/john-sambrook-headshot-1200.jpg"
            alt="John Sambrook, founder of Common Sense Systems"
            width="1200"
            height="857"
            loading="eager"
            decoding="async"
            class="mx-auto w-40 h-40 sm:w-48 sm:h-48 rounded-full object-cover border-4 border-background shadow-sm"
          />
        </picture>
      </div>
    </div>
  </Section>

  <Section>
    <div class="max-w-3xl mx-auto space-y-6 text-sm text-muted-foreground">
      {
        content.map((block) => (
          <p class:list={[block.lead && 'text-foreground text-base']}>{block.text}</p>
        ))
      }
    </div>
  </Section>

  <Section background="muted">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl sm:text-3xl text-center mb-8">Professional Credentials</h2>
      <p class="text-sm text-muted-foreground text-center mb-8">
        Issued by <a
          href="https://www.tocico.org/"
          target="_blank"
          rel="noopener"
          class="text-accent hover:underline">TOCICO</a
        >, the international certification body for Theory of Constraints.
      </p>
      <div class="space-y-6">
        {
          credentials.map((cred) => (
            <div class="bg-background rounded-xl p-6 shadow-sm border border-border">
              <h3 class="text-base font-semibold mb-1">{cred.name}</h3>
              <p class="text-sm text-muted-foreground mb-3">{cred.description}</p>
              <div class="flex flex-wrap gap-x-6 gap-y-1 text-xs text-muted-foreground">
                <span>Earned {cred.dateEarned}</span>
                <a
                  href={cred.verifyUrl}
                  target="_blank"
                  rel="noopener"
                  class="text-accent hover:underline"
                >
                  Verify on TOCICO.org
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </Section>

  <TestimonialsSection />

  <CTASection
    headline={cta.headline}
    description={cta.description}
    primaryCta={cta.primaryCta}
    secondaryCta={cta.secondaryCta}
  />
</PageLayout>
